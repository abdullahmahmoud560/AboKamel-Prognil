# .env.example - Template for environment variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Production

# MySQL Root Password (for docker-compose)
USERNAME=Prognil
MYSQL_ROOT_PASSWORD=YourRootPasswordHere
DB_USER=abokamel_app
DB_PASSWORD=YourAppUserPasswordHere

ADMIN_USERNAME=root
ADMIN_PASSWORD=YourAdminPasswordHere

# Database Connection
# For Docker Compose deployment:
ConnectionStrings__DefaultConnection=Server=abokamel-mysql;Port=3306;Database=abokamel;User=${DB_USER};Password=${DB_PASSWORD};

# For local development (if running API outside Docker):
# ConnectionStrings__DefaultConnection=Server=localhost;Port=3306;Database=abokamel;User=${DB_USER};Password=${DB_PASSWORD};

# JWT Configuration
JWT__Key=YourSuperSecretJwtKeyHere
JWT__Issuer=Prognil
JWT__Audience=PlatformUsers
JWT__DurationInDays=1
